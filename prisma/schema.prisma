// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Roles {
  admin
  superadmin
  member
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Roles     @default(member)
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Image {
  id       String   @id @default(cuid())
  url      String
  width    Int
  height   Int
  banner   Channel? @relation("ImageToBanner", fields: [bannerId], references: [id])
  bannerId String?
  avatar   Channel? @relation(fields: [avatarId], references: [id])
  avatarId String?
}

model Channel {
  id          String   @id @unique
  name        String
  description String
  avatar      Image[]
  isVerified  Boolean  @map("is_verified")
  url         String
  banner      Image[]  @relation("ImageToBanner")
  subscribers String
  joined      String
  country     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
